---
import { defaultLocale } from "../../constants"
import { languages } from "@libs/i18n"
import BlogSection from '@components/sections/Blog/index.astro'
import Layout from "@layouts/Layout.astro"

const currentLanguageDescription =
	languages.find((language) => language.key === Astro.currentLocale)?.description
	|| defaultLocale
---
<Layout title={`Blog (${currentLanguageDescription})`}>
		<BlogSection />
</Layout>