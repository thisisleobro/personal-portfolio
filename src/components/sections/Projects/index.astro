---
interface Props {
	headerLevel?: number
	featured?: string[]
}

import {t} from 'i18next'
import { getImage } from 'astro:assets'
import kantu from '../../../assets/kantu.png'
import keypirinhaQrCodeVideo from '@assets/keypirinha-qrcode.mp4?inline'
import keypirinhaQrCodeImage from '@assets/keypirinha-qrcode.jpg'
const optimizedKeypirinhaQrCode = await getImage({src: keypirinhaQrCodeImage, width: 1024})
import Markview from '../../../assets/markview.png'
import ExcelToSaft from '../../../assets/excel-to-saftcv.png'

import Project from './Project.astro'
import Heading from '@components/Heading.astro'

const {headerLevel, featured} = Astro.props
---

<section id='projects'>
	<Heading
	level={headerLevel}
	title={featured? t('projects.title_featured'): t('projects.title')}
	subtitle={featured && t('projects.subtitle')}
	/>
	<ul class="flex flex-col gap-4">
		<Project
		id='Keypirinha-qrcode'
		name={t('projects.keypirinha-qrcode.name')}
		description={t('projects.keypirinha-qrcode.description')}
		videoSrc={keypirinhaQrCodeVideo}
		poster={optimizedKeypirinhaQrCode.src}
		features={t('projects.keypirinha-qrcode.features', { returnObjects: true })}
		todos={t('projects.keypirinha-qrcode.todos', {returnObjects: true})}
		links={{
			github: 'https://github.com/thisisleobro/Keypirinha-qrcode',
		}}
		featuredProjects={featured}
		/>

		<Project
		id='markview'
		name={t('projects.markview.name')}
		description={t('projects.markview.description')}
		imageSrc={Markview}
		features={t('projects.markview.features', { returnObjects: true })}
		todos={t('projects.markview.todos', {returnObjects: true})}
		links={{
			github: 'https://github.com/thisisleobro/markview',
		}}
		featuredProjects={featured}
		/>
		
		<Project
		id='excel-to-saft'
		name={t('projects.saftcv.name')}
		description={t('projects.saftcv.description')}
		imageSrc={ExcelToSaft}
		features={t('projects.saftcv.features', { returnObjects: true })}
		todos={t('projects.saftcv.todos', {returnObjects: true})}
		links={{
			website: 'https://saft.carvalho.cv',
		}}
		featuredProjects={featured}
		/>

		<Project
		id='kantu'
		name={t('projects.kantu.name')}
		description={t('projects.kantu.description')}
		imageSrc={kantu}
		features={t('projects.kantu.features', { returnObjects: true })}
		todos={t('projects.kantu.todos', {returnObjects: true})}
		featuredProjects={featured}
		/>

	</ul>
</section>
