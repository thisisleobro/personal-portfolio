---
import {ChevronDownIcon, ChevronUpIcon} from 'astro-feather';
interface Props {
	anchor: string,
	direction?: 'down' | 'up',
	id?: string,
	containerClass?: string,
	iconClass?: string,
}
const {id = 'scroll', anchor, direction = 'down', containerClass, iconClass} = Astro.props
---
<button class={containerClass} id={id} aria-label="Scroll down">
	<div class={iconClass}>
		{direction === 'down' && <ChevronDownIcon />}
		{direction === 'up' && <ChevronUpIcon />}
	</div>
</button>

<script is:inline define:vars={{id, anchor}}>
	document.addEventListener('astro:page-load', () => {
		const scroll = document.getElementById(id)

		if (anchor) {
			scroll?.addEventListener('click', () => {location.hash = anchor})
		}
	}, false)
</script>